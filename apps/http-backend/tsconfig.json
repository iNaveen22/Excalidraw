{
    "extends": "@repo/typescript-config/base.json",
    "compilerOptions": {
        "module": "CommonJS",
        "moduleResolution": "Node",
        "target": "ES2020",
        "outDir": "dist",
        "rootDir": "src",
        "baseUrl": ".",
        "esModuleInterop": true,
        "strict": true
    },
    "include": [
        "src"
    ],
    "typeRoots": [
        "./src/types",
        "./node_modules/@types"
    ]
}